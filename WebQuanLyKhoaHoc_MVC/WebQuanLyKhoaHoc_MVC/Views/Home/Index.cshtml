@{
    ViewData["Title"] = "Trang chủ Quản trị";
}

<div class="container mt-4 mb-5">
    <div class="p-5 mb-5 bg-light rounded-4 shadow-sm border-0 text-center" style="background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);">
        <div class="container-fluid py-2">
            <h1 class="display-5 fw-bold text-primary mb-3">
                <i class="bi bi-mortarboard-fill me-2"></i>Hệ Thống Quản Lý Đào Tạo
            </h1>
            <p class="col-md-8 mx-auto fs-5 text-muted">
                Chào mừng bạn đến với trang quản trị trung tâm. Vui lòng chọn một trong các chức năng dưới đây để bắt đầu quản lý dữ liệu.
            </p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 transition-hover" style="border-radius: 16px;">
                <div class="card-body text-center p-4">
                    <div class="mb-3 mt-2">
                        <i class="bi bi-people-fill text-primary" style="font-size: 3.5rem;"></i>
                    </div>
                    <h5 class="card-title fw-bold">Quản lý Sinh viên</h5>
                    <p class="card-text text-muted small px-2">Xem danh sách, thêm mới, sửa và xóa thông tin hồ sơ sinh viên.</p>
                    <a asp-controller="Student" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4 mt-2 fw-medium">Truy cập ngay</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 transition-hover" style="border-radius: 16px;">
                <div class="card-body text-center p-4">
                    <div class="mb-3 mt-2">
                        <i class="bi bi-person-badge-fill text-dark" style="font-size: 3.5rem;"></i>
                    </div>
                    <h5 class="card-title fw-bold">Quản lý Giảng viên</h5>
                    <p class="card-text text-muted small px-2">Cập nhật danh sách giảng viên và bộ môn giảng dạy tương ứng.</p>
                    <a asp-controller="Teacher" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4 mt-2 fw-medium">Truy cập ngay</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 transition-hover" style="border-radius: 16px;">
                <div class="card-body text-center p-4">
                    <div class="mb-3 mt-2">
                        <i class="bi bi-book-half text-info" style="font-size: 3.5rem;"></i>
                    </div>
                    <h5 class="card-title fw-bold">Quản lý Môn học</h5>
                    <p class="card-text text-muted small px-2">Thiết lập danh mục môn học và cấu hình số lượng tín chỉ.</p>
                    <a asp-controller="Course" asp-action="Index" class="btn btn-outline-info rounded-pill px-4 mt-2 fw-medium text-dark">Truy cập ngay</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-6">
            <div class="card h-100 shadow-sm border-0 transition-hover" style="border-radius: 16px;">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="me-4 ms-2">
                        <i class="bi bi-journal-bookmark-fill" style="font-size: 4rem; color: #008080;"></i>
                    </div>
                    <div>
                        <h5 class="card-title fw-bold" style="color: #008080;">Mở Lớp Học Phần</h5>
                        <p class="card-text text-muted small mb-3">Phân công giảng viên dạy các môn học theo từng học kỳ và năm học.</p>
                        <a asp-controller="CourseClass" asp-action="Index" class="btn rounded-pill px-4 fw-medium" style="border: 1px solid #008080; color: #008080;">Quản lý Lớp</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-6">
            <div class="card h-100 shadow-sm border-0 transition-hover" style="border-radius: 16px;">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="me-4 ms-2">
                        <i class="bi bi-card-checklist" style="font-size: 4rem; color: #6f42c1;"></i>
                    </div>
                    <div>
                        <h5 class="card-title fw-bold" style="color: #6f42c1;">Đăng Ký & Vào Điểm</h5>
                        <p class="card-text text-muted small mb-3">Ghi nhận sinh viên đăng ký vào các lớp học phần và nhập điểm số.</p>
                        <a asp-controller="Enrollment" asp-action="Index" class="btn rounded-pill px-4 fw-medium" style="border: 1px solid #6f42c1; color: #6f42c1;">Quản lý Đăng ký</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
    }

        .transition-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.15) !important;
        }
</style>s