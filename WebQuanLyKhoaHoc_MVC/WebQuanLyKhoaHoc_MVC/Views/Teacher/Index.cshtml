@model IEnumerable<learnMVC.Models.Teacher>

@{
    ViewData["Title"] = "Danh sách Giảng viên";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0">Quản lý Giảng viên</h4>
            <a asp-action="Create" class="btn btn-outline-light btn-sm fw-bold">
                + Thêm Giảng viên
            </a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4">#ID</th>
                        <th>Họ và Tên</th>
                        <th>Bộ môn (Subject)</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4 fw-bold text-secondary">@item.Id</td>
                            <td class="fw-medium">@item.Name</td>
                            <td><span class="badge bg-secondary">@item.Subject</span></td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">Sửa</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Xem</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Xóa</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>