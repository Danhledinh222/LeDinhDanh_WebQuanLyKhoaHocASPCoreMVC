@model learnMVC.Models.Enrollment

@{
    ViewData["Title"] = "Cập nhật / Vào Điểm";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-warning py-3">
                    <h5 class="mb-0 text-dark">Cập Nhật Thông Tin / Vào Điểm</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-3">
                            <label asp-for="StudentId" class="form-label fw-bold">Sinh Viên <span class="text-danger">*</span></label>
                            <select asp-for="StudentId" class="form-select" asp-items="ViewBag.StudentId"></select>
                            <span asp-validation-for="StudentId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="CourseClassId" class="form-label fw-bold">Lớp Học Phần <span class="text-danger">*</span></label>
                            <select asp-for="CourseClassId" class="form-select" asp-items="ViewBag.CourseClassId"></select>
                            <span asp-validation-for="CourseClassId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Grade" class="form-label fw-bold">Điểm Số</label>
                            <input asp-for="Grade" type="number" step="0.1" class="form-control" />
                            <span asp-validation-for="Grade" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end border-top pt-3">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">Quay lại</a>
                            <input type="submit" value="Cập nhật" class="btn btn-warning fw-bold" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}