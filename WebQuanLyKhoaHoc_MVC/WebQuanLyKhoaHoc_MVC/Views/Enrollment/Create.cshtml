@model learnMVC.Models.Enrollment

@{
    ViewData["Title"] = "Thêm Đăng ký mới";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header text-white py-3" style="background-color: #6f42c1;">
                    <h5 class="mb-0">Sinh Viên Đăng Ký Lớp</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="StudentId" class="form-label fw-bold">Sinh Viên <span class="text-danger">*</span></label>
                            <select asp-for="StudentId" class="form-select" asp-items="ViewBag.StudentId">
                                <option value="">-- Chọn sinh viên --</option>
                            </select>
                            <span asp-validation-for="StudentId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="CourseClassId" class="form-label fw-bold">Lớp Học Phần <span class="text-danger">*</span></label>
                            <select asp-for="CourseClassId" class="form-select" asp-items="ViewBag.CourseClassId">
                                <option value="">-- Chọn lớp học phần --</option>
                            </select>
                            <span asp-validation-for="CourseClassId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Grade" class="form-label fw-bold">Điểm Số (Có thể nhập sau)</label>
                            <input asp-for="Grade" type="number" step="0.1" class="form-control" placeholder="Để trống nếu chưa có điểm" />
                            <span asp-validation-for="Grade" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end border-top pt-3">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">Quay lại</a>
                            <input type="submit" value="Lưu Đăng Ký" class="btn" style="background-color: #6f42c1; color: white;" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}