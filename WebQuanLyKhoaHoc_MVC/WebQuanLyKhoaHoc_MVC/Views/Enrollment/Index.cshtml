@model IEnumerable<learnMVC.Models.Enrollment>

@{
    ViewData["Title"] = "Danh sách Đăng ký";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header text-white d-flex justify-content-between align-items-center py-3" style="background-color: #6f42c1;">
            <h4 class="mb-0"><i class="bi bi-card-checklist"></i> Quản lý Đăng ký Lớp</h4>
            <a asp-action="Create" class="btn btn-light btn-sm fw-bold shadow-sm" style="color: #6f42c1;">
                + Thêm Đăng ký
            </a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-light text-center">
                    <tr>
                        <th class="px-4 text-start">#ID</th>
                        <th class="text-start">Sinh Viên</th>
                        <th class="text-start">Lớp Học Phần (Môn)</th>
                        <th>Điểm Số</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4 fw-bold text-secondary text-start">@item.Id</td>
                            <td class="fw-bold text-start text-dark">@item.Student?.Name</td>
                            <td class="text-start">
                                <span class="fw-medium text-primary">@item.CourseClass?.Course?.CourseName</span>
                                <br />
                                <small class="text-muted">HK @item.CourseClass?.Semester - @item.CourseClass?.Year</small>
                            </td>
                            <td class="text-center">
                                @if (item.Grade.HasValue)
                                {
                                    <span class="badge @(item.Grade >= 5 ? "bg-success" : "bg-danger") fs-6">
                                        @item.Grade
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Chưa có điểm</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">Sửa/Vào Điểm</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Xem</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Xóa</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>