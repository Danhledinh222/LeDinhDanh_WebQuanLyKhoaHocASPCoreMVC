@model IEnumerable<learnMVC.Models.Course>

@{
    ViewData["Title"] = "Danh sách Môn học";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary bg-gradient text-white d-flex justify-content-between align-items-center py-3">
            <h4 class="mb-0"><i class="bi bi-book"></i> Quản lý Môn học</h4>
            <a asp-action="Create" class="btn btn-light btn-sm fw-bold text-primary shadow-sm">
                + Thêm Môn học mới
            </a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0 text-center align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 text-start">#ID</th>
                        <th class="text-start">Tên Môn Học</th>
                        <th>Số Tín Chỉ</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4 fw-bold text-secondary text-start">@item.Id</td>
                            <td class="fw-medium text-primary text-start">@item.CourseName</td>
                            <td>
                                <span class="badge rounded-pill bg-info text-dark px-3 py-2 fs-6">
                                    @item.Credits tín chỉ
                                </span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">Sửa</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Xem</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Xóa</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>